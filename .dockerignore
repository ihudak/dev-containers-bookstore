# Exclude version control and documentation from the Docker build context.
.git
.gitignore
*.md
LICENSE

# Exclude discovery/blocked capture artifacts.
.agent-discovery
.agent-blocked

# Exclude the fragment directories — only the assembled allowlist-*.txt files
# are needed inside the image (generated by runme.sh build).
allowlist-domains.d
allowlist-proxy-domains.d
allowlist-cidrs.d

# Exclude sandbox.conf — it's only read by runme.sh on the host, not inside the image.
sandbox.conf
